{
  "name": "inception-reality-engine",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run prepare:repo && npm run dev -w @inception/web",
    "dev:mock": "node scripts/run-codex-mode.mjs mock",
    "dev:real": "node scripts/run-codex-mode.mjs real",
    "codex:check": "node scripts/run-codex-mode.mjs check",
    "build": "npm run prepare:repo && npm run build -w @inception/web",
    "start": "npm run start -w @inception/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "typecheck": "npm run typegen -w @inception/web && tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "demo:reset": "tsx scripts/reset-demo.ts",
    "verify": "npm run test && npm run typecheck && npm run build",
    "judge:demo": "npm run dev:real",
    "record:demo": "npm run dev:mock",
    "prepare:repo": "node scripts/ensure-git.mjs"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "7.8.0",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.24.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "22.15.30",
    "postcss": "^8.5.10",
    "prisma": "7.8.0",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vitest": "4.1.10"
  },
  "type": "module",
  "engines": {
    "node": ">=22.15.0"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "next": {
      "postcss": "8.5.10"
    },
    "vite": {
      "postcss": "8.5.10"
    }
  }
}
